# DarkShield Frontend Environment Variables
# Rename this file to .env.local and fill in your actual values

# Backend API base URL
VITE_API_URL=http://localhost:9091

# Groq API Key (only needed if calling Groq directly from frontend — NOT recommended)
# For production, always call Groq through your Spring Boot backend
# VITE_GROQ_API_KEY=your-groq-api-key-here
